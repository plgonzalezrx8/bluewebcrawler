{
  "name": "bluewebcrawler",
  "version": "0.1.2",
  "description": "A hybrid HTTP + browser web crawler that exports AI-ready markdown.",
  "type": "module",
  "bin": {
    "bluewebcrawler": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist output output-* coverage",
    "dev": "tsx src/cli/index.ts",
    "crawl": "tsx src/cli/index.ts crawl",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepack": "npm run clean && npm run build",
    "release:check": "npm run lint && npm run test && npm run build && npm pack --dry-run"
  },
  "keywords": [
    "crawler",
    "playwright",
    "markdown",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "commander": "^14.0.2",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.54.2",
    "robots-parser": "^3.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
